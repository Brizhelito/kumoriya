{
  "enabled": true,
  "name": "Validate Task on Completion",
  "description": "Runs the full validation checklist (format, analyze, tests) after a spec task is marked completed",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "A spec task was just completed. Run the full Kumoriya validation checklist before marking it as done:\n\n1. dart format — run on all affected paths and confirm output is clean\n2. dart analyze — run on affected packages and confirm zero errors\n3. dart test — run relevant tests for the slice and report pass/fail\n4. Confirm the targeted flow was actually exercised, not just compiled\n5. Report residual risk honestly\n\nOutput the Task Validation Report:\n1. What changed:\n2. What was validated (format / analyze / tests / flow exercised):\n3. What was NOT validated (and why):\n4. Residual risk:\n5. Recommended next step:"
  }
}