{
  "name": "watch-party-realtime",
  "version": "0.1.0",
  "description": "Party Realtime Service - Cloudflare Workers with Durable Objects for watch party state management",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext .ts"
